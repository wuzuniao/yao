# ============================================================
# 后端环境变量模板（复制为 .env 后填入实际值，.env 不提交 Git）
# ============================================================

# ---------------------- 数据库配置 ----------------------
# MariaDB 连接字符串
# 格式：mysql+asyncmy://用户名:密码@主机:端口/数据库名?charset=utf8mb4
# 开发环境：127.0.0.1:3306；生产环境：mariadb 容器服务名或内网 IP
DATABASE_URL=mysql+asyncmy://root:your_password@127.0.0.1:3306/wuzuniao_yao?charset=utf8mb4

# ------------------ 腾讯企业邮 SMTP 配置 ------------------
# 用于发送注册验证码邮件，使用前请填写企业邮箱账号与授权码（客户端专用密码）
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=your_email@your_domain.com
SMTP_PASSWORD=your_smtp_password
SMTP_SENDER_NAME=无足鸟

# ------------------- 微信小程序配置 -------------------
# 微信公众平台 → 开发管理 → 开发设置 中获取
WX_APPID=your_wx_appid
WX_APP_SECRET=your_wx_app_secret

# ------------------- 数据加密密钥 -------------------
# AES-256-GCM 加密密钥（base64 编码的 32 字节密钥）
# 用于加密邮件客户端专用密码等敏感信息，请妥善保管，泄露后所有加密数据需重新加密
# 生成方式：python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_SECRET_KEY=your_base64_encoded_32_byte_key
